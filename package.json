{
  "name": "fatigue-detection",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "description": "基于 MediaPipe Face Mesh 的面部疲劳检测 ",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./css/style.css -o ./dist/tailwind-preview.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.cjs -i ./css/style.css -o ./dist/tailwind-preview.css --watch",
    "preview": "vite preview",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run build && npx cap run android"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/share": "^8.0.0"
  }
}
